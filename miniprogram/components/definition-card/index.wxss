:host {
  display: block;
}

/* ===== Glass Card ===== */
.glass-card {
  position: relative;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.55), rgba(235, 233, 250, 0.35));
  backdrop-filter: blur(48rpx);
  -webkit-backdrop-filter: blur(48rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 64rpx;
  padding: 56rpx;
  border-bottom-color: rgba(255, 255, 255, 0.2);
  border-right-color: rgba(255, 255, 255, 0.2);
  box-shadow:
    8rpx 8rpx 24rpx rgba(89, 91, 140, 0.18),
    -6rpx -6rpx 20rpx rgba(255, 255, 255, 0.7),
    inset 2rpx 2rpx 6rpx rgba(255, 255, 255, 0.6);
  animation: cardFadeIn 0.5s ease-out both;
}

/* ===== Translate Button ===== */
.card-top-right {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
}

.translate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(240, 238, 255, 0.7), rgba(215, 212, 245, 0.4));
  flex-shrink: 0;
  box-shadow:
    6rpx 6rpx 16rpx rgba(89, 91, 140, 0.18),
    -4rpx -4rpx 12rpx rgba(255, 255, 255, 0.7),
    inset 1rpx 1rpx 4rpx rgba(255, 255, 255, 0.6);
}

.translate-icon {
  font-size: 24rpx;
  font-weight: 700;
  color: #595b8c;
}

/* ===== Section ===== */
.section {
  margin-bottom: 8rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.section-title-secondary {
  color: #5d5d72;
}

.section-body {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #32323b;
  line-height: 52rpx;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: rgba(179, 176, 188, 0.2);
  margin: 36rpx 0;
}

/* ===== Example ===== */
.example-block {
  padding-left: 40rpx;
  border-left: 6rpx solid #e2e0f9;
}

.example-text {
  font-size: 32rpx;
  font-style: italic;
  font-weight: 300;
  color: #5f5e68;
  line-height: 50rpx;
}

/* ===== Animation ===== */
@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
