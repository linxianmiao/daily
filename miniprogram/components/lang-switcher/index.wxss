.lang-switcher-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 420rpx;
  padding: 8rpx;
  border-radius: 9999rpx;
  gap: 16rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.55), rgba(235, 233, 250, 0.35));
  backdrop-filter: blur(48rpx);
  -webkit-backdrop-filter: blur(48rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow:
    6rpx 6rpx 16rpx rgba(89, 91, 140, 0.18),
    -4rpx -4rpx 12rpx rgba(255, 255, 255, 0.7),
    inset 1rpx 1rpx 4rpx rgba(255, 255, 255, 0.6);
}

.lang-option {
  flex: 1;
  text-align: center;
  padding: 14rpx 32rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: rgba(95, 94, 104, 0.6);
  transition: all 0.3s ease;
  white-space: nowrap;
}

.lang-active {
  background: #595b8c;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(89, 91, 140, 0.3);
}
