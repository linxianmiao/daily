.card {
  height: 100%;
  padding: 48rpx;
  background: linear-gradient(to bottom, #fcf8fe, #f6f2fb);
}

.card-content {
  position: relative;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(179, 176, 188, 0.1);
  border-radius: 64rpx;
  padding: 66rpx;
  height: 100%;
  box-shadow: 0 40rpx 120rpx rgba(50, 50, 59, 0.06);
  overflow: hidden;
}

.visual-accent {
  position: absolute;
  top: -64rpx;
  right: -64rpx;
  width: 256rpx;
  height: 256rpx;
  background: rgba(196, 196, 252, 0.2);
  filter: blur(40rpx);
  border-bottom-left-radius: 160rpx;
}

.card-label {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: #5f5e68;
  text-transform: uppercase;
}

.card-hashtag {
  font-size: 72rpx;
  font-weight: 800;
  color: #32323b;
  line-height: 80rpx;
  letter-spacing: -3.6rpx;
  margin-top: 24rpx;
  word-break: break-word;
}

/* Definitions */
.definitions {
  flex: 1;
  margin-top: 40rpx;
  overflow-y: auto;
}

.def-item {
  display: flex;
  margin-bottom: 36rpx;
}

.def-item:last-child {
  margin-bottom: 0;
}

.def-number {
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  background: rgba(89, 91, 140, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #595b8c;
  margin-right: 24rpx;
  margin-top: 4rpx;
}

.def-body {
  flex: 1;
  min-width: 0;
}

.def-text {
  font-size: 28rpx;
  color: #32323b;
  line-height: 44rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.def-example {
  margin-top: 12rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid rgba(89, 91, 140, 0.2);
}

.def-example-text {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 38rpx;
  font-style: italic;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* Button */
.explore-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #595b8c;
  border-radius: 9999rpx;
  padding: 32rpx 0;
  width: 100%;
  margin-top: 40rpx;
  flex-shrink: 0;
}

.explore-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fbf7ff;
  letter-spacing: -0.8rpx;
}

.explore-btn-arrow {
  font-size: 32rpx;
  color: #fbf7ff;
}
