<view class="card">
  <view class="card-content">
    <view class="visual-accent"></view>
    <text class="card-label">GLOBAL TREND</text>
    <text class="card-hashtag">{{keyword}}</text>

    <view class="definitions">
      <view class="def-item" wx:for="{{definitions}}" wx:key="index">
        <view class="def-number">{{index + 1}}</view>
        <view class="def-body">
          <text class="def-text">{{item.definition}}</text>
          <view class="def-example" wx:if="{{item.example}}">
            <text class="def-example-text">"{{item.example}}"</text>
          </view>
        </view>
      </view>
    </view>

    <view class="explore-btn" bindtap="onExploreInsights">
      <text class="explore-btn-text">Explore Insights</text>
      <text class="explore-btn-arrow">→</text>
    </view>
  </view>
</view>
