.demo-row {
  margin-bottom: 32rpx;
}

.demo-row:last-child {
  margin-bottom: 0;
}

.demo-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  height: 34rpx;
}

.demo-label {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.1rpx;
  color: #505064;
  text-transform: uppercase;
}

.demo-pct {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.1rpx;
  color: #505064;
  text-transform: uppercase;
}

.demo-track {
  width: 100%;
  height: 12rpx;
  background: #f0ecf6;
  border-radius: 9999rpx;
  overflow: hidden;
}

.demo-fill {
  height: 100%;
  border-radius: 9999rpx;
  transition: width 0.6s ease;
}
