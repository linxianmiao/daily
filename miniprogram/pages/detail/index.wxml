<view class="page-container">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="back-btn" bindtap="onBack">
        <text class="back-arrow">←</text>
      </view>
      <text class="nav-title">#{{keyword}}</text>
    </view>
  </view>

  <view class="content" style="margin-top: {{statusBarHeight + 44}}px;">
    <view class="detail-card">
      <text class="card-label">KEYWORD DETAIL</text>
      <text class="card-hashtag">#{{keyword}}</text>

      <view wx:if="{{loading}}" class="loading-text">Loading history...</view>

      <view wx:if="{{history.length > 0}}" class="history-section">
        <text class="section-title">7-Day Trend</text>
        <view class="history-list">
          <view wx:for="{{history}}" wx:key="date" class="history-item">
            <text class="history-date">{{item.date}}</text>
            <view class="history-bar-track">
              <view class="history-bar-fill" style="width: {{item.weight * 100}}%;"></view>
            </view>
            <text class="history-value">{{item.weight}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!loading && history.length === 0}}" class="empty-text">No history data available</view>
    </view>
  </view>
</view>
