.page-container {
  min-height: 100vh;
  background: #F5F5F7;
}

.top-nav {
  background: #FFFFFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 32rpx;
}

.back-btn {
  margin-right: 16rpx;
  padding: 8rpx;
}

.back-arrow {
  font-size: 36rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content {
  padding: 24rpx 32rpx;
}

.detail-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
}

.card-label {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: #A0A0A8;
  display: block;
  margin-bottom: 16rpx;
}

.card-hashtag {
  font-size: 52rpx;
  font-weight: 800;
  color: #1A1A2E;
  display: block;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 24rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-date {
  font-size: 22rpx;
  color: #8E8E93;
  width: 120rpx;
  flex-shrink: 0;
}

.history-bar-track {
  flex: 1;
  height: 12rpx;
  background: #F0F0F5;
  border-radius: 6rpx;
  overflow: hidden;
}

.history-bar-fill {
  height: 100%;
  background: #6C63FF;
  border-radius: 6rpx;
  min-width: 4rpx;
}

.history-value {
  font-size: 22rpx;
  color: #1A1A2E;
  font-weight: 600;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.loading-text,
.empty-text {
  text-align: center;
  padding: 60rpx;
  color: #A0A0A8;
  font-size: 28rpx;
}
