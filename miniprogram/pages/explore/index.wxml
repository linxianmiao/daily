<swiper
  class="page"
  vertical="{{true}}"
  duration="{{300}}"
  easing-function="easeInOutCubic"
  bindchange="onSwiperChange"
  current="{{currentIndex}}"
  circular="{{true}}"
  wx:if="{{!loading}}"
>
  <swiper-item wx:for="{{slots}}" wx:key="index">
    <scroll-view class="card-scroll" scroll-y enhanced show-scrollbar="{{false}}" scroll-top="{{scrollTops[index]}}" wx:if="{{item}}">
      <view class="content">

        <!-- Top Bar: Language Switcher + Share -->
        <view class="top-bar">
          <lang-switcher category="{{category}}" bind:change="switchCategory" />
          <share-btn />
        </view>

        <!-- Trend Header -->
        <view class="header">
          <text class="keyword">{{item.keyword}}</text>
          <text class="pinyin" wx:if="{{item.pinyin}}">{{item.pinyin}}</text>
        </view>

        <!-- Definition Cards -->
        <view class="feed">
          <definition-card
            wx:for="{{item.definitions}}"
            wx:for-item="def"
            wx:for-index="defIdx"
            wx:key="defIdx"
            def="{{def}}"
            defIdx="{{defIdx}}"
            bind:togglelang="onCardToggleLang"
            data-slot-idx="{{index}}"
          />
        </view>

        <view class="bottom-hint">
          <view class="swipe-up-circle">
            <view class="chevron chevron-top"></view>
            <view class="chevron chevron-bottom"></view>
          </view>
        </view>
        <view class="bottom-spacer"></view>

      </view>
    </scroll-view>
  </swiper-item>
</swiper>

<view class="loading" wx:if="{{loading}}">
  <!-- Top Bar 骨架屏 -->
  <view class="top-bar">
    <view class="skeleton-lang-switcher"></view>
    <view class="skeleton-share-btn"></view>
  </view>

  <!-- 骨架屏：关键词占位 -->
  <view class="skeleton-bar skeleton-keyword"></view>
  <view class="skeleton-bar skeleton-pinyin"></view>

  <!-- 骨架屏：第一张卡片 -->
  <view class="skeleton-card">
    <view class="skeleton-bar skeleton-title"></view>
    <view class="skeleton-bar skeleton-line skeleton-line-full"></view>
    <view class="skeleton-bar skeleton-line skeleton-line-3q"></view>
    <view class="skeleton-divider"></view>
    <view class="skeleton-bar skeleton-title"></view>
    <view class="skeleton-example">
      <view class="skeleton-bar skeleton-line skeleton-line-full"></view>
      <view class="skeleton-bar skeleton-line skeleton-line-half"></view>
    </view>
  </view>

  <!-- 骨架屏：第二张卡片（带延迟） -->
  <view class="skeleton-card" style="animation-delay: 0.3s;">
    <view class="skeleton-bar skeleton-title"></view>
    <view class="skeleton-bar skeleton-line skeleton-line-full"></view>
    <view class="skeleton-bar skeleton-line skeleton-line-half"></view>
  </view>
</view>
