.page {
  height: 100vh;
}

.card-scroll {
  height: 100%;
  background: linear-gradient(135deg, #fcf8fe 0%, #e2e0f9 50%, #f5cdf9 100%);
}

.content {
  padding: 80rpx 32rpx 0;
  min-height: 100%;
}

/* ===== Header ===== */
.header {
  padding: 0 16rpx;
  margin-bottom: 64rpx;
}

.tags {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.tag-primary {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: #595b8c;
  background: rgba(196, 196, 252, 0.3);
  padding: 6rpx 24rpx;
  border-radius: 9999rpx;
}

.tag-meta {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: #5f5e68;
  text-transform: uppercase;
}

.keyword {
  display: block;
  font-size: 96rpx;
  font-weight: 800;
  color: #32323b;
  letter-spacing: -4rpx;
  line-height: 1;
  word-break: break-word;
}

/* ===== Feed ===== */
.feed {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ===== Glass Card ===== */
.glass-card {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(48rpx);
  -webkit-backdrop-filter: blur(48rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 64rpx;
  padding: 56rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-icon-text {
  font-size: 28rpx;
  font-weight: 700;
}

.card-label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #5f5e68;
  text-transform: uppercase;
}

/* ===== Section ===== */
.section {
  margin-bottom: 8rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.section-title-secondary {
  color: #5d5d72;
}

.section-body {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #32323b;
  line-height: 52rpx;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: rgba(179, 176, 188, 0.2);
  margin: 36rpx 0;
}

/* ===== Example ===== */
.example-block {
  padding-left: 40rpx;
  border-left: 6rpx solid #e2e0f9;
}

.example-text {
  font-size: 32rpx;
  font-style: italic;
  font-weight: 300;
  color: #5f5e68;
  line-height: 50rpx;
}

/* ===== Actions ===== */
.card-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 40rpx;
  padding-top: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.4);
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
}

.action-icon {
  font-size: 26rpx;
}

.action-count {
  font-size: 26rpx;
  font-weight: 500;
  color: #32323b;
}

/* ===== Bottom ===== */
.bottom-hint {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 16rpx;
}

.bottom-hint-text {
  font-size: 22rpx;
  color: #b3b0bc;
  letter-spacing: 1rpx;
}

.bottom-spacer {
  height: 120rpx;
}

/* ===== Loading ===== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #5f5e68;
}
