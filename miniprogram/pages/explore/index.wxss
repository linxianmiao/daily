.page {
  height: 100vh;
}

.card-scroll {
  height: 100%;
  background: linear-gradient(135deg, #fcf8fe 0%, #e2e0f9 50%, #f5cdf9 100%);
}

.content {
  padding: 80rpx 32rpx 0;
  min-height: 100%;
}

/* ===== Top Bar ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
  margin-top: 85rpx;
}

.skeleton-lang-switcher {
  width: 420rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  background: rgba(89, 91, 140, 0.08);
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-share-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(89, 91, 140, 0.08);
  flex-shrink: 0;
  animation: shimmer 1.5s ease-in-out infinite;
}

/* ===== Header ===== */
.header {
  padding: 0rpx 16rpx 0 16rpx;
  margin-bottom: 64rpx;
}

.keyword {
  display: block;
  font-size: 96rpx;
  font-weight: 800;
  color: #32323b;
  letter-spacing: -4rpx;
  line-height: 1;
  word-break: break-word;
}

.pinyin {
  display: block;
  font-size: 32rpx;
  font-weight: 400;
  color: #7a7889;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* ===== Feed ===== */
.feed {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ===== Bottom ===== */
.bottom-hint {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 16rpx;
}

.bottom-spacer {
  height: 120rpx;
}

/* ===== Swipe Up Circle ===== */
.swipe-up-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(240, 238, 255, 0.6), rgba(210, 207, 240, 0.4));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  animation: gentleBounce 2s ease-in-out infinite;
  box-shadow:
    6rpx 6rpx 16rpx rgba(89, 91, 140, 0.18),
    -4rpx -4rpx 12rpx rgba(255, 255, 255, 0.7),
    inset 1rpx 1rpx 4rpx rgba(255, 255, 255, 0.6);
}

.chevron {
  width: 28rpx;
  height: 28rpx;
  border-left: 4rpx solid #8b8aad;
  border-top: 4rpx solid #8b8aad;
  transform: rotate(45deg);
  border-radius: 4rpx;
}

.chevron-top {
  margin-bottom: -12rpx;
}

.chevron-bottom {
  opacity: 0.5;
}

/* ===== Animations ===== */
@keyframes gentleBounce {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-16rpx); }
}

@keyframes shimmer {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 0.7; }
}

/* ===== Loading Skeleton ===== */
.loading {
  height: 100vh;
  background: linear-gradient(135deg, #fcf8fe 0%, #e2e0f9 50%, #f5cdf9 100%);
  padding: 80rpx 32rpx 0;
}

.skeleton-bar {
  border-radius: 16rpx;
  background: rgba(89, 91, 140, 0.08);
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-keyword {
  width: 280rpx;
  height: 80rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-pinyin {
  width: 200rpx;
  height: 32rpx;
  margin-left: 16rpx;
  margin-bottom: 64rpx;
}

.skeleton-card {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(48rpx);
  -webkit-backdrop-filter: blur(48rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 64rpx;
  padding: 56rpx;
  margin-bottom: 40rpx;
  box-shadow:
    0 20rpx 60rpx -20rpx rgba(89, 91, 140, 0.1),
    inset 0 2rpx 2rpx rgba(255, 255, 255, 0.8);
}

.skeleton-card:last-child {
  animation-delay: 0.3s;
}

.skeleton-title {
  width: 140rpx;
  height: 22rpx;
  margin-bottom: 20rpx;
}

.skeleton-line {
  height: 32rpx;
  margin-bottom: 16rpx;
}

.skeleton-line-full { width: 100%; }
.skeleton-line-3q   { width: 75%; }
.skeleton-line-half { width: 50%; }

.skeleton-divider {
  height: 1rpx;
  background: rgba(179, 176, 188, 0.15);
  margin: 36rpx 0;
}

.skeleton-example {
  padding-left: 40rpx;
  border-left: 6rpx solid rgba(226, 224, 249, 0.5);
}

.skeleton-example .skeleton-line {
  height: 28rpx;
}
