.page {
  height: 100vh;
}

.card-scroll {
  height: 100%;
  background: linear-gradient(135deg, #fcf8fe 0%, #e2e0f9 50%, #f5cdf9 100%);
}

.content {
  padding: 80rpx 32rpx 0;
  min-height: 100%;
}

/* ===== Header ===== */
.header {
  padding: 80rpx 16rpx 0 16rpx;
  margin-bottom: 64rpx;
}

.keyword {
  display: block;
  font-size: 96rpx;
  font-weight: 800;
  color: #32323b;
  letter-spacing: -4rpx;
  line-height: 1;
  word-break: break-word;
}

/* ===== Feed ===== */
.feed {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ===== Glass Card ===== */
.glass-card {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(48rpx);
  -webkit-backdrop-filter: blur(48rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 64rpx;
  padding: 56rpx;
  border-bottom-color: rgba(255, 255, 255, 0.2);
  border-right-color: rgba(255, 255, 255, 0.2);
  box-shadow:
    0 20rpx 60rpx -20rpx rgba(89, 91, 140, 0.15),
    0 40rpx 120rpx -30rpx rgba(89, 91, 140, 0.1),
    inset 0 2rpx 2rpx rgba(255, 255, 255, 0.8),
    inset 0 -2rpx 2rpx rgba(0, 0, 0, 0.05);
  animation: cardFadeIn 0.5s ease-out both;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-icon-text {
  font-size: 28rpx;
  font-weight: 700;
}

.card-label {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #5f5e68;
  text-transform: uppercase;
}

/* ===== Section ===== */
.section {
  margin-bottom: 8rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.section-title-secondary {
  color: #5d5d72;
}

.section-body {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #32323b;
  line-height: 52rpx;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: rgba(179, 176, 188, 0.2);
  margin: 36rpx 0;
}

/* ===== Example ===== */
.example-block {
  padding-left: 40rpx;
  border-left: 6rpx solid #e2e0f9;
}

.example-text {
  font-size: 32rpx;
  font-style: italic;
  font-weight: 300;
  color: #5f5e68;
  line-height: 50rpx;
}

/* ===== Pinyin ===== */
.pinyin {
  display: block;
  font-size: 32rpx;
  font-weight: 400;
  color: #7a7889;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* ===== Card Footer ===== */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
  padding-top: 16rpx;
}

/* ===== Translate Button ===== */
.translate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(89, 91, 140, 0.08);
  flex-shrink: 0;
}

.translate-icon {
  font-size: 24rpx;
  font-weight: 700;
  color: #595b8c;
}

/* ===== Actions ===== */
.card-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.4);
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
}

.action-icon {
  font-size: 26rpx;
}

.action-count {
  font-size: 26rpx;
  font-weight: 500;
  color: #32323b;
}

/* ===== Bottom ===== */
.bottom-hint {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 16rpx;
  animation: floatHint 2s ease-in-out infinite;
}

.bottom-hint-text {
  font-size: 22rpx;
  color: #b3b0bc;
  letter-spacing: 1rpx;
}

.bottom-spacer {
  height: 120rpx;
}

/* ===== Animations ===== */
@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes floatHint {
  0%, 100% { transform: translateY(0); opacity: 0.5; }
  50%      { transform: translateY(-12rpx); opacity: 1; }
}

@keyframes shimmer {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 0.7; }
}

/* ===== Loading Skeleton ===== */
.loading {
  height: 100vh;
  background: linear-gradient(135deg, #fcf8fe 0%, #e2e0f9 50%, #f5cdf9 100%);
  padding: 160rpx 32rpx 0;
}

.skeleton-bar {
  border-radius: 16rpx;
  background: rgba(89, 91, 140, 0.08);
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-keyword {
  width: 280rpx;
  height: 80rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-pinyin {
  width: 200rpx;
  height: 32rpx;
  margin-left: 16rpx;
  margin-bottom: 64rpx;
}

.skeleton-card {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(48rpx);
  -webkit-backdrop-filter: blur(48rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 64rpx;
  padding: 56rpx;
  margin-bottom: 40rpx;
  box-shadow:
    0 20rpx 60rpx -20rpx rgba(89, 91, 140, 0.1),
    inset 0 2rpx 2rpx rgba(255, 255, 255, 0.8);
}

.skeleton-card:last-child {
  animation-delay: 0.3s;
}

.skeleton-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.skeleton-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.skeleton-label {
  width: 200rpx;
  height: 28rpx;
}

.skeleton-title {
  width: 140rpx;
  height: 22rpx;
  margin-bottom: 20rpx;
}

.skeleton-line {
  height: 32rpx;
  margin-bottom: 16rpx;
}

.skeleton-line-full { width: 100%; }
.skeleton-line-3q   { width: 75%; }
.skeleton-line-half { width: 50%; }

.skeleton-divider {
  height: 1rpx;
  background: rgba(179, 176, 188, 0.15);
  margin: 36rpx 0;
}

.skeleton-example {
  padding-left: 40rpx;
  border-left: 6rpx solid rgba(226, 224, 249, 0.5);
}

.skeleton-example .skeleton-line {
  height: 28rpx;
}
