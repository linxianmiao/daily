<view class="page-container">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">Insights</text>
    </view>
  </view>

  <view class="content" style="margin-top: {{statusBarHeight + 44}}px;">
    <view wx:if="{{loading}}" class="loading-text">Loading...</view>

    <!-- Categories -->
    <view wx:if="{{categories.length > 0}}" class="section">
      <text class="section-title">Categories</text>
      <view class="category-grid">
        <view wx:for="{{categories}}" wx:key="category" class="category-card">
          <text class="category-name">{{item.category}}</text>
          <text class="category-count">{{item.count}} topics</text>
        </view>
      </view>
    </view>

    <!-- AI Topics -->
    <view wx:if="{{aiTopics.length > 0}}" class="section">
      <text class="section-title">AI-Generated Topics</text>
      <view class="topics-list">
        <view wx:for="{{aiTopics}}" wx:key="index" class="topic-card">
          <text class="topic-name">{{item.topic}}</text>
          <text class="topic-desc">{{item.description}}</text>
          <view class="topic-meta">
            <text class="topic-category">{{item.category}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!loading && aiTopics.length === 0 && categories.length === 0}}" class="empty-text">No insights data</view>
  </view>
</view>
