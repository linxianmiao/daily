.page-container {
  min-height: 100vh;
  background: #F5F5F7;
}

.top-nav {
  background: #FFFFFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 32rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.content {
  padding: 24rpx 32rpx;
  padding-bottom: 140rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 20rpx;
  display: block;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.category-count {
  font-size: 22rpx;
  color: #A0A0A8;
  margin-top: 8rpx;
}

.topics-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.topic-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
}

.topic-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}

.topic-desc {
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.6;
  display: block;
}

.topic-meta {
  margin-top: 12rpx;
}

.topic-category {
  font-size: 22rpx;
  color: #6C63FF;
  font-weight: 500;
  background: rgba(108, 99, 255, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.loading-text,
.empty-text {
  text-align: center;
  padding: 60rpx;
  color: #A0A0A8;
  font-size: 28rpx;
}
