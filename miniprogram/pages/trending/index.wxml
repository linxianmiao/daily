<view class="page-container">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">Trending</text>
    </view>
  </view>

  <view class="content" style="margin-top: {{statusBarHeight + 44}}px;">
    <!-- Platform Filter -->
    <scroll-view class="platform-scroll" scroll-x>
      <view class="platform-list">
        <view
          wx:for="{{platforms}}"
          wx:key="id"
          class="platform-tag {{currentPlatform === item.id ? 'active' : ''}}"
          data-platform="{{item.id}}"
          bindtap="onPlatformChange"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- Trending List -->
    <view class="trending-list">
      <view wx:if="{{loading}}" class="loading-text">Loading...</view>
      <view wx:for="{{trendingList}}" wx:key="index" class="trending-item">
        <view class="rank">{{index + 1}}</view>
        <view class="item-content">
          <text class="item-title">{{item.title}}</text>
          <view class="item-meta">
            <text class="item-platform">{{item.platform}}</text>
            <text class="item-hot" wx:if="{{item.hot_value}}">{{item.hot_value}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{!loading && trendingList.length === 0}}" class="empty-text">No trending data</view>
    </view>
  </view>
</view>
