.tab-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  height: 120rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
}

.icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 56rpx;
  border-radius: 28rpx;
  transition: background 0.2s;
}

.icon-active {
  background: rgba(45, 43, 127, 0.08);
  width: 100rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}

.text-active {
  color: #2D2B7F;
}

/* Compass Icon */
.icon-compass {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.compass-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #8E8E93;
}

.icon-compass.active .compass-circle {
  border-color: #2D2B7F;
}

.compass-needle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 16rpx;
  background: #8E8E93;
  transform: translate(-50%, -50%) rotate(45deg);
  border-radius: 2rpx;
}

.icon-compass.active .compass-needle {
  background: #2D2B7F;
}

/* Trending Icon */
.icon-trending {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.trending-line {
  position: absolute;
  bottom: 4rpx;
  left: 2rpx;
  width: 28rpx;
  height: 3rpx;
  background: #8E8E93;
  transform: rotate(-30deg);
  transform-origin: left bottom;
}

.icon-trending.active .trending-line {
  background: #2D2B7F;
}

.trending-arrow {
  position: absolute;
  top: 6rpx;
  right: 4rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-bottom: 8rpx solid #8E8E93;
  transform: rotate(-30deg);
}

.icon-trending.active .trending-arrow {
  border-bottom-color: #2D2B7F;
}

/* Insights Icon */
.icon-insights {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.bar {
  width: 8rpx;
  border-radius: 2rpx;
  background: #8E8E93;
}

.icon-insights.active .bar {
  background: #2D2B7F;
}

.bar1 { height: 16rpx; }
.bar2 { height: 28rpx; }
.bar3 { height: 22rpx; }

/* Profile Icon */
.icon-profile {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.profile-head {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 3rpx solid #8E8E93;
  margin-bottom: 2rpx;
}

.icon-profile.active .profile-head {
  border-color: #2D2B7F;
}

.profile-body {
  width: 24rpx;
  height: 12rpx;
  border-radius: 12rpx 12rpx 0 0;
  border: 3rpx solid #8E8E93;
  border-bottom: none;
}

.icon-profile.active .profile-body {
  border-color: #2D2B7F;
}
