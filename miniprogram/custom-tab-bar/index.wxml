<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="icon-wrapper {{selected === index ? 'icon-active' : ''}}">
      <!-- Compass / Explore -->
      <view wx:if="{{item.icon === 'compass'}}" class="tab-icon">
        <view class="icon-compass {{selected === index ? 'active' : ''}}">
          <view class="compass-circle"></view>
          <view class="compass-needle"></view>
        </view>
      </view>
      <!-- Trending -->
      <view wx:elif="{{item.icon === 'trending'}}" class="tab-icon">
        <view class="icon-trending {{selected === index ? 'active' : ''}}">
          <view class="trending-line"></view>
          <view class="trending-arrow"></view>
        </view>
      </view>
      <!-- Insights -->
      <view wx:elif="{{item.icon === 'insights'}}" class="tab-icon">
        <view class="icon-insights {{selected === index ? 'active' : ''}}">
          <view class="bar bar1"></view>
          <view class="bar bar2"></view>
          <view class="bar bar3"></view>
        </view>
      </view>
      <!-- Profile -->
      <view wx:elif="{{item.icon === 'profile'}}" class="tab-icon">
        <view class="icon-profile {{selected === index ? 'active' : ''}}">
          <view class="profile-head"></view>
          <view class="profile-body"></view>
        </view>
      </view>
    </view>
    <text class="tab-text {{selected === index ? 'text-active' : ''}}">{{item.text}}</text>
  </view>
</view>
